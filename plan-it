doctor_opencode() {
  echo ""
  info "=== plan-it doctor (opencode) v$VERSION ==="
  echo ""

  local errors=0
  local warnings=0

  # Check manifest
  if [ ! -f "$OPCODE_MANIFEST" ]; then
    err "  \u274c Manifest missing: $OPCODE_MANIFEST"
    errors=$((errors + 1))
  else
    msg "  \u2705 Manifest present"
  fi

  # Check AGENTS.md sentinel integrity
  if [ -f "$OPCODE_CONFIG_DIR/AGENTS.md" ]; then
    local sentinel_result
    sentinel_result=$(validate_sentinels "$OPCODE_CONFIG_DIR/AGENTS.md" 2>&1 || true)
    local sentinel_rc=$?
    if [ "$sentinel_rc" -gt 0 ]; then
      err "  \u274c AGENTS.md sentinel issues: $sentinel_result"
      errors=$((errors + 1))
    else
      msg "  \u2705 AGENTS.md sentinels valid"
    fi
  else
    err "  \u274c AGENTS.md missing"
    errors=$((errors + 1))
  fi

  # Check opencode.json
  if [ -f "$OPCODE_CONFIG_DIR/opencode.json" ]; then
    if node -e "JSON.parse(require('fs').readFileSync('$OPCODE_CONFIG_DIR/opencode.json','utf-8'))" 2>/dev/null; then
      msg "  \u2705 opencode.json valid JSON"
    else
      err "  \u274c opencode.json invalid JSON"
      errors=$((errors + 1))
    fi
  else
    err "  \u274c opencode.json missing"
    errors=$((errors + 1))
  fi

  # Check tool files
  for f in "tools/list-plans.ts" "tools/stale-plans.ts" "tools/related-plans.ts"; do
    if [ -f "$OPCODE_CONFIG_DIR/$f" ]; then
      if head -3 "$OPCODE_CONFIG_DIR/$f" | grep -q "doc-it-managed: true"; then
        msg "  \u2705 $f (managed)"
      else
        warn "  \u26a0 $f (user-modified or missing managed header)"
        warnings=$((warnings + 1))
      fi
    else
      err "  \u274c $f missing"
      errors=$((errors + 1))
    fi
  done

  # Check AGENTS references to .ai/*.md
  if [ -f "$OPCODE_CONFIG_DIR/AGENTS.md" ]; then
    local refs
    refs=$(grep -oP '\.ai/[^\s)]+' "$OPCODE_CONFIG_DIR/AGENTS.md" 2>/dev/null || true)
    if [ -n "$refs" ]; then
      warn "  \u26a0 AGENTS.md references .ai/ files (project-level concern, not global)"
      warnings=$((warnings + 1))
    fi
  fi

  echo ""
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    msg "plan-it (opencode): healthy"
  elif [ "$errors" -eq 0 ]; then
    warn "plan-it (opencode): $warnings warning(s)"
  else
    err "plan-it (opencode): $errors error(s), $warnings warning(s)"
  fi
  echo ""
  return "$errors"
}

