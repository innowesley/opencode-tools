import { readdir } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

const STATUS_DIRS: Record<string, string[]> = {
  drafts: [".opencode/plans"],
  pending: [".agents/plans/pending"],
  active: [".opencode/plans", ".agents/plans/pending"],
  completed: [".agents/plans/completed"],
}

async function readPlans(base: string, dir: string): Promise<string[]> {
  let files: string[]
  try {
    files = await readdir(`${base}/${dir}`)
  } catch {
    return []
  }
  return files
    .filter(f => f.endsWith(".md"))
    .map(f => f.replace(/\.md$/, ""))
}

export default tool({
  description: "List plan files by status (default: active = drafts + pending)",
  args: {
    status: tool.schema.enum(["drafts", "pending", "active", "completed"]).default("active").describe("drafts = .opencode/plans/, pending = .agents/plans/pending/, active = both, completed = archived"),
  },
  async execute(args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const dirs = STATUS_DIRS[args.status]
    if (!dirs) {
      return JSON.stringify({ count: 0, plans: [], error: `Unknown status: ${args.status}` })
    }

    const allPlans = await Promise.all(dirs.map(d => readPlans(base, d)))
    const plans = [...new Set(allPlans.flat())]

    return JSON.stringify({ count: plans.length, plans, status: args.status })
  },
})
