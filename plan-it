# ---------------------------------------------------------------------------
# Usage / dispatch
# ---------------------------------------------------------------------------

usage() {
  echo "Usage: $0 <command> [<cli>] [<project-dir>]"
  echo ""
  echo "Commands:"
  echo "  install <cli>              Install plan-it globally (kilo|opencode)"
  echo "  init <cli> <project>       Initialize project structure"
  echo "  deinit <cli> <project>     Remove project-level plan-it (add --clean to remove plan dirs)"
  echo "  uninstall <cli>            Remove plan-it (kilo|opencode)"
  echo "  status [<cli>]             Show installed components (kilo|opencode|all)"
  echo "  doctor [<cli>]             Read-only diagnostics (kilo|opencode|all)"
  echo "  list                       List active plans"
  echo ""
  echo "Examples:"
  echo "  $0 install kilo"
  echo "  $0 install opencode"
  echo "  $0 init opencode ./my-project"
  echo "  $0 deinit opencode ./my-project"
  echo "  $0 deinit opencode ./my-project --clean"
  echo "  $0 uninstall opencode"
  echo "  $0 status"
  echo "  $0 doctor"
  echo "  $0 doctor opencode"
  echo ""
  echo "Aliases: add = install, rm = uninstall"
}

case "${1:-help}" in
  install|add)
    case "${2:-}" in
      kilo)
        install_kilo
        if [ -n "${3:-}" ]; then
          warn "'install <cli> <project>' is deprecated. Use 'init <cli> <project>'"
          init_kilo_project "$3"
        fi
        ;;
      opencode)
        install_opencode
        if [ -n "${3:-}" ]; then
          warn "'install <cli> <project>' is deprecated. Use 'init <cli> <project>'"
          init_opencode_project "$3"
        fi
        ;;
      *) err "Usage: $0 install <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  init)
    case "${2:-}" in
      kilo) init_kilo_project "${3:-.}" ;;
      opencode) init_opencode_project "${3:-.}" ;;
      *) err "Usage: $0 init <kilo|opencode> [project-dir]"; exit 1 ;;
    esac
    ;;
  deinit)
    case "${2:-}" in
      kilo) deinit_kilo_project "${3:-.}" "${4:-}" ;;
      opencode) deinit_opencode_project "${3:-.}" "${4:-}" ;;
      *) err "Usage: $0 deinit <kilo|opencode> [project-dir] [--clean]"; exit 1 ;;
    esac
    ;;
  uninstall|rm)
    case "${2:-}" in
      kilo) uninstall_kilo ;;
      opencode) uninstall_opencode ;;
      *) err "Usage: $0 uninstall <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  status)
    case "${2:-all}" in
      kilo) show_status_kilo ;;
      opencode) show_status_opencode ;;
      all|"") show_status_kilo; show_status_opencode ;;
      *) err "Usage: $0 status [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  doctor)
    case "${2:-all}" in
      kilo) doctor_kilo ;;
      opencode) doctor_opencode ;;
      all|"") doctor_kilo; doctor_opencode ;;
      *) err "Usage: $0 doctor [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  list)
    warn "list not yet implemented"
    echo "Plans go in:"
    echo "  .opencode/plans/           (drafts)"
    echo "  .kilo/plans/               (drafts)"
    echo "  .agents/plans/pending/     (in-progress)"
    echo "  .agents/plans/completed/   (archived)"
    ;;
  help|--help|-h)
    usage
    ;;
  upgrade)
    msg "Upgrade not yet implemented. Re-run 'install' to refresh managed assets."
    ;;
  repair)
    warn "repair not yet implemented. Use 'doctor' to check status."
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
