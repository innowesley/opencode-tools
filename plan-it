uninstall_opencode() {
  warn "Uninstalling plan-it (opencode)..."

  if [ -f "$OPCODE_MANIFEST" ]; then
    node -e "
      const fs = require('fs');
      const m = JSON.parse(fs.readFileSync('$OPCODE_MANIFEST', 'utf-8'));
      for (const f of m.files) {
        if (f.ownership === 'user') continue;
        try {
          fs.unlinkSync(f.path);
          console.log('  Removed: ' + f.path);
        } catch (e) {
          if (e.code !== 'ENOENT') console.error('  Error removing ' + f.path + ': ' + e.message);
        }
      }
    "
    rm -f "$OPCODE_MANIFEST"
  else
    for f in "$OPCODE_CONFIG_DIR/opencode.json" "$OPCODE_CONFIG_DIR/AGENTS.md" \
      "$OPCODE_CONFIG_DIR/tools/list-plans.ts" \
      "$OPCODE_CONFIG_DIR/tools/stale-plans.ts" "$OPCODE_CONFIG_DIR/tools/related-plans.ts" \
      "$OPCODE_CONFIG_DIR/commands/pending.md" "$OPCODE_CONFIG_DIR/sudo-managed.sh"; do
      [ -f "$f" ] && rm "$f" && info "  Removed: $f"
    done
    rm -rf "$OPCODE_CONFIG_DIR/skills" 2>/dev/null || true
  fi

  safe_rmdir "$OPCODE_CONFIG_DIR/tools"
  safe_rmdir "$OPCODE_CONFIG_DIR/commands"

  # Safe plan removal — only remove if empty after manifest-based uninstall
  for dir in "$HOME/.agents/plans/pending" "$HOME/.agents/plans/completed"; do
    if [ -d "$dir" ]; then
      local has_files=false
      shopt -s nullglob dotglob
      for _ in "$dir"/*; do has_files=true; break; done
      shopt -u nullglob dotglob
      if ! $has_files; then
        rmdir "$dir" && info "  Removed empty directory: $dir"
      else
        warn "  Skipping $dir — contains user files"
      fi
    fi
  done
  safe_rmdir "$HOME/.agents/plans"

  if [ -f /etc/opencode/opencode.json ]; then
    warn "  Note: /etc/opencode/opencode.json (reference config) must be removed manually (sudo)"
  fi

  msg "Opencode uninstall complete"
}

uninstall_kilo() {
  warn "Uninstalling plan-it (Kilo)..."

  if [ -f "$KILO_MANIFEST" ]; then
    node -e "
      const fs = require('fs');
      const m = JSON.parse(fs.readFileSync('$KILO_MANIFEST', 'utf-8'));
      for (const f of m.files) {
        if (f.ownership === 'user') continue;
        try {
          const stat = fs.statSync(f.path);
          if (stat.isDirectory()) {
            fs.rmSync(f.path, { recursive: true, force: true });
          } else {
            fs.unlinkSync(f.path);
          }
          console.log('  Removed: ' + f.path);
        } catch (e) {
          if (e.code !== 'ENOENT') console.error('  Error removing ' + f.path + ': ' + e.message);
        }
      }
    "
    rm -f "$KILO_MANIFEST"
  else
    rm -rf "$KILO_PLUGIN_DIR" 2>/dev/null || true
    info "  Removed plugin: $KILO_PLUGIN_DIR"

    if [ -f "$KILO_CONFIG_DIR/kilo.jsonc" ]; then
      cp "$KILO_CONFIG_DIR/kilo.jsonc" "$KILO_CONFIG_DIR/kilo.jsonc.bak.$(date +%Y%m%d%H%M%S)"
      node -e "
        const fs = require('fs');
        const content = fs.readFileSync('$KILO_CONFIG_DIR/kilo.jsonc', 'utf-8');
        function stripJsonc(t){let out='',i=0,s=!1,c='';for(;i<t.length;i++){const ch=t[i];if(s){out+=ch;if(ch==='\\\\'){i++;out+=t[i];continue}if(ch===c)s=!1;continue}if(ch==='\"'||ch===\"'\"){s=!0;c=ch;out+=ch;continue}if(ch==='/'&&t[i+1]==='/'){while(i<t.length&&t[i]!=='\\n')i++;continue}if(ch==='/'&&t[i+1]==='*'){i+=2;while(i<t.length-1&&!(t[i]==='*'&&t[i+1]==='/'))i++;i+=2;continue}out+=ch}return out}
        const noComments = stripJsonc(content);
        const config = JSON.parse(noComments);
        const plugins = (config.plugin || []).filter(p => p !== '@opencode-tools/kilo-plugin');
        const pluginStr = JSON.stringify(plugins);
        if (/\\\"plugin\\\"\\s*:/.test(content)) {
          content = content.replace(/\\\"plugin\\\"\\s*:\\s*\\[[^\\]]*\\]/, '\"plugin\": ' + pluginStr);
        }
        fs.writeFileSync('$KILO_CONFIG_DIR/kilo.jsonc', content);
      "
      prune_backups "$KILO_CONFIG_DIR/kilo.jsonc.bak.*" 3
      info "  Removed plugin from kilo.jsonc"
    fi
  fi

  remove_managed_block "$KILO_CONFIG_DIR/AGENTS.md" "$PLANIT_KILO_BEGIN" "$PLANIT_KILO_END"
  if [ -f "$KILO_CONFIG_DIR/AGENTS.md" ] && [ ! -s "$KILO_CONFIG_DIR/AGENTS.md" ]; then
    rm -f "$KILO_CONFIG_DIR/AGENTS.md"
  fi

  msg "Kilo uninstall complete"
}

