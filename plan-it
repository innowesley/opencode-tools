          async function scanDir(dir) {
            let files
            try { files = await readdir(dir) } catch { return [] }
            const results = []
            for (const file of files) {
              if (!file.endsWith(".md")) continue
              const name = file.replace(/\.md$/, "")
              if (name === args.planName) continue
              let content, mtimeMs
              try { content = await readFile(`${dir}/${file}`, "utf-8"); const s = await stat(`${dir}/${file}`); mtimeMs = s.mtimeMs } catch { continue }
              const score = scoreMatch(topics, name, content)
              if (score > 0) results.push({ name, matchScore: score, mtimeMs })
            }
            results.sort((a, b) => { if (b.matchScore !== a.matchScore) return b.matchScore - a.matchScore; return (b.mtimeMs ?? 0) - (a.mtimeMs ?? 0) })
            return results.map(r => ({ name: r.name, matchScore: r.matchScore }))
          }
          const [relatedDrafts, relatedPending, allRelatedCompleted] = await Promise.all([scanDir(draftsDir), scanDir(pendingDir), scanDir(completedDir)])
          const relatedCompleted = allRelatedCompleted.slice(0, 3)
          return JSON.stringify({ analyzedPlan: args.planName, planSource, topics, relatedDrafts, relatedPending, relatedCompleted })
        },
      }),
      "stale-plans": tool({
        description: "Check pending plans for staleness",
        args: { maxAgeDays: tool.schema.number().default(7).describe("Max age in days before stale") },
        async execute(args, context) {
          const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
          const [draftsResult, pendingResult] = await Promise.all([
            checkDirStaleness(`${base}/.kilo/plans`, "drafts", args.maxAgeDays),
            checkDirStaleness(`${base}/.agents/plans/pending`, "pending", args.maxAgeDays),
          ])
          return JSON.stringify({ count: draftsResult.count + pendingResult.count, stale: [...draftsResult.stale, ...pendingResult.stale], healthy: [...draftsResult.healthy, ...pendingResult.healthy] })
        },
      }),
    }
  }
}
TOOLEOF
  manifest_add "$KILO_MANIFEST" "$KILO_PLUGIN_DIR/dist/plan-it.js" "managed" "$VERSION"

  (cd "$KILO_PLUGIN_DIR" && npm install --no-audit --no-fund --loglevel=error) || { err "npm install failed in $KILO_PLUGIN_DIR"; return 1; }

  # --- kilo.jsonc plugin registration (Node.js, not sed) ---
  KILO_JSONC="$KILO_CONFIG_DIR/kilo.jsonc"
  if [ -f "$KILO_JSONC" ]; then
    cp "$KILO_JSONC" "$KILO_JSONC.bak.$(date +%Y%m%d%H%M%S)"
    manifest_add "$KILO_MANIFEST" "$KILO_JSONC" "managed"

    node -e "
      const fs = require('fs');
      const jsoncPath = process.argv[1];
      const pluginName = process.argv[2];
      let content = fs.readFileSync(jsoncPath, 'utf-8');

      if (content.includes(pluginName)) {
        console.log('Plugin @opencode-tools/kilo-plugin already registered in kilo.jsonc');
        process.exit(0);
      }

      function stripJsonc(t){let out='',i=0,s=!1,c='';for(;i<t.length;i++){const ch=t[i];if(s){out+=ch;if(ch==='\\'){i++;out+=t[i];continue}if(ch===c)s=!1;continue}if(ch==='"'||ch==="'"){s=!0;c=ch;out+=ch;continue}if(ch==='/'&&t[i+1]==='/'){while(i<t.length&&t[i]!=='\n')i++;continue}if(ch==='/'&&t[i+1]==='*'){i+=2;while(i<t.length-1&&!(t[i]==='*'&&t[i+1]==='/'))i++;i+=2;continue}out+=ch}return out}
      const noComments = stripJsonc(content);
      const config = JSON.parse(noComments);
      config.plugin = config.plugin || [];
      config.plugin.push(pluginName);

      const pluginStr = JSON.stringify(config.plugin);
      if (/\"plugin\"\\s*:/.test(content)) {
        content = content.replace(/\"plugin\"\\s*:\\s*\[[\\s\\S]*?\]/, '\"plugin\": ' + pluginStr);
      } else {
        content = content.replace(/(\"\\\$schema\"[^,]+),/, '\$1,\\n  \"plugin\": ' + pluginStr + ',');
      }
      fs.writeFileSync(jsoncPath, content);
      console.log('Registered plugin in kilo.jsonc');
    " "$KILO_JSONC" "@opencode-tools/kilo-plugin"

    prune_backups "$KILO_JSONC.bak.*" 3
  else
    err "kilo.jsonc not found at $KILO_JSONC"
    err "Run 'kilo' at least once to generate the config file"
  fi

  # --- Kilo AGENTS.md managed block ---
  local kilo_agents_block
  kilo_agents_block=$(cat << 'AGENTS_BLOCK'
## Plan-First Protocol

On ANY task:
1. Create plan → `.kilo/plans/<task>.md` (use **descriptive names**)
2. Use the `question` tool to gather input — do NOT skip
3. Self-review: is this the safest, simplest approach for the goal?
4. Before finalizing, analyze compatibility with existing logic:
   - Map affected execution paths, hidden coupling, shared utilities
   - Check assumptions other features rely on
   - Verify impact on existing users, data, workflows
   - Analyze rollback safety
5. Every plan must include: Existing Logic Analysis, Potential Conflicts, Backward Compatibility, Migration/Rollout Strategy, Risk Assessment, Regression Prevention, Testing Strategy
6. Prefer minimally invasive solutions, incremental refactors, preserve stable interfaces
7. Return plan to user
8. STOP – do NOT execute

Execute ONLY after: "execute", "proceed", "continue", or explicit approval.

Note: The `write` tool is permitted for `.kilo/plans/**/*.md` and `.agents/plans/**/*.md` in Plan mode. All bash commands (`mv`, `rm`) run in Build mode only — they are the first action after the mode switch.

---

## Execution Rules (entirely in Build mode)

After user approves (now in Build mode):
1. `mv .kilo/plans/<task>.md .agents/plans/pending/<task>.md` (NEVER use `cp`)
2. Execute the plan, updating `.agents/plans/pending/<task>.md` continuously
3. Mark steps [x] as completed
4. Append progress logs

On completion:
1. Status → completed
2. `mv .agents/plans/pending/<task>.md .agents/plans/completed/<task>.md` (NEVER use `cp`)
3. Return: result + next-step plan
AGENTS_BLOCK
)

  replace_managed_block "$KILO_CONFIG_DIR/AGENTS.md" \
    "$PLANIT_KILO_BEGIN" "$PLANIT_KILO_END" "$kilo_agents_block"
  manifest_add "$KILO_MANIFEST" "$KILO_CONFIG_DIR/AGENTS.md" "managed"

  msg "Plan-it (Kilo) v$VERSION install complete!"
  info "  Plugin: @opencode-tools/kilo-plugin"
  info "  Tools: list-plans, related-plans, stale-plans"
  info "  Start a Kilo session and ask: list plans"
}

