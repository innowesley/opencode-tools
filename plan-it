uninstall_opencode() {
  warn "Uninstalling plan-it (opencode)..."

  for f in "$OPCODE_CONFIG_DIR/opencode.json" "$OPCODE_CONFIG_DIR/AGENTS.md" \
    "$OPCODE_CONFIG_DIR/tools/list-plans.ts" \
    "$OPCODE_CONFIG_DIR/tools/stale-plans.ts" "$OPCODE_CONFIG_DIR/tools/related-plans.ts" \
    "$OPCODE_CONFIG_DIR/commands/pending.md" "$OPCODE_CONFIG_DIR/sudo-managed.sh"; do
    if [ -f "$f" ]; then
      rm "$f"
      info "  Removed: $f"
    fi
  done

  rm -rf "$OPCODE_CONFIG_DIR/skills" 2>/dev/null || true
  rmdir "$OPCODE_CONFIG_DIR/tools" 2>/dev/null || true
  rmdir "$OPCODE_CONFIG_DIR/commands" 2>/dev/null || true
  rm -rf "$HOME/.agents/plans" 2>/dev/null || true

  if [ -f /etc/opencode/opencode.json ]; then
    warn "  Note: /etc/opencode/opencode.json (managed) must be removed manually (sudo)"
  fi

  msg "Opencode uninstall complete"
}

uninstall_kilo() {
  warn "Uninstalling plan-it (Kilo)..."

  rm -rf "$KILO_PLUGIN_DIR" 2>/dev/null || true
  info "  Removed plugin: $KILO_PLUGIN_DIR"

  if [ -f "$KILO_CONFIG_DIR/kilo.jsonc" ]; then
    cp "$KILO_CONFIG_DIR/kilo.jsonc" "$KILO_CONFIG_DIR/kilo.jsonc.bak.$(date +%Y%m%d%H%M%S)"
    sed -i 's/  "plugin": \["@opencode-tools\/kilo-plugin"\],\?//' "$KILO_CONFIG_DIR/kilo.jsonc"
    sed -i '/^  "plugin": \[\]/d' "$KILO_CONFIG_DIR/kilo.jsonc"
    info "  Removed plugin from kilo.jsonc"
  fi

  rm -f "$KILO_CONFIG_DIR/AGENTS.md" 2>/dev/null || true
  info "  Removed: $KILO_CONFIG_DIR/AGENTS.md"

  msg "Kilo uninstall complete"
}

show_status_opencode() {
  echo ""
  info "=== plan-it status (opencode) ==="
  echo ""

  local all_ok=true

  for f in "opencode.json" "AGENTS.md" "commands/pending.md" "sudo-managed.sh"; do
    if [ -f "$OPCODE_CONFIG_DIR/$f" ]; then
      msg "  ✅ $f"
    else
      err "  ❌ $f"
      all_ok=false
    fi
  done

  for f in "tools/list-plans.ts" "tools/stale-plans.ts" "tools/related-plans.ts"; do
    if [ -f "$OPCODE_CONFIG_DIR/$f" ]; then
      msg "  ✅ $f"
    else
      err "  ❌ $f"
      all_ok=false
    fi
  done

  echo ""
  if $all_ok; then
    msg "plan-it (opencode) is fully installed"
  else
    err "plan-it (opencode) is incomplete — run 'install' to fix"
  fi

  if [ -f /etc/opencode/opencode.json ]; then
    msg "  ✅ Managed config at /etc/opencode/opencode.json (unoverridable)"
  fi
  echo ""
}

show_status_kilo() {
  echo ""
  info "=== plan-it status (Kilo) ==="
  echo ""

  local all_ok=true

  if [ -d "$KILO_PLUGIN_DIR" ]; then
    msg "  ✅ Plugin directory: $KILO_PLUGIN_DIR"
  else
    err "  ❌ Plugin directory missing"
    all_ok=false
  fi

  if [ -f "$KILO_PLUGIN_DIR/dist/plan-it.js" ]; then
    msg "  ✅ PlanItPlugin: $KILO_PLUGIN_DIR/dist/plan-it.js"
  else
    err "  ❌ PlanItPlugin missing"
    all_ok=false
  fi

  if grep -q "@opencode-tools/kilo-plugin" "$KILO_CONFIG_DIR/kilo.jsonc" 2>/dev/null; then
    msg "  ✅ Plugin registered in kilo.jsonc"
  else
    warn "  ⬜ Plugin not registered in kilo.jsonc"
  fi

  if [ -d ".kilo/plans" ] && [ -d ".agents/plans/pending" ] && [ -d ".agents/plans/completed" ]; then
    msg "  ✅ plan directories present (.kilo/plans/ + .agents/plans/)"
  else
    warn "  ⬜ plan directories not found (create with mkdir -p .kilo/plans .agents/plans/pending .agents/plans/completed)"
  fi

  if [ -f "$KILO_CONFIG_DIR/AGENTS.md" ]; then
    msg "  ✅ Kilo AGENTS.md"
  else
    warn "  ⬜ Kilo AGENTS.md not at $KILO_CONFIG_DIR/AGENTS.md"
  fi

  echo ""
  if $all_ok; then
    msg "plan-it (Kilo) is fully installed"
  else
    err "plan-it (Kilo) is incomplete — run 'install' to fix"
  fi
  echo ""
}

usage() {
  echo "Usage: $0 <command> [<cli>]"
  echo ""
  echo "Commands:"
  echo "  install <cli>      Install plan-it (kilo|opencode)"
  echo "  uninstall <cli>    Remove plan-it (kilo|opencode)"
  echo "  status [<cli>]     Show installed components (kilo|opencode|all)"
  echo "  list               List active plans"
  echo ""
  echo "Examples:"
  echo "  $0 install kilo"
  echo "  $0 install opencode"
  echo "  $0 uninstall opencode"
  echo "  $0 status"
  echo "  $0 status kilo"
  echo "  $0 list"
  echo ""
  echo "Aliases: add = install, rm = uninstall"
}

case "${1:-help}" in
  install|add)
    case "${2:-}" in
      kilo) install_kilo ;;
      opencode) install_opencode ;;
      *) err "Usage: $0 install <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  uninstall|rm)
    case "${2:-}" in
      kilo) uninstall_kilo ;;
      opencode) uninstall_opencode ;;
      *) err "Usage: $0 uninstall <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  status)
    case "${2:-all}" in
      kilo) show_status_kilo ;;
      opencode) show_status_opencode ;;
      all|"") show_status_kilo; show_status_opencode ;;
      *) err "Usage: $0 status [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  list)
    warn "list not yet implemented"
    echo "Plans go in:"
    echo "  .kilo/plans/            (drafts)"
    echo "  .agents/plans/pending/  (in-progress)"
    echo "  .agents/plans/completed/ (archived)"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
