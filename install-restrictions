#!/bin/bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

msg()  { printf "${GREEN}%s${NC}\n" "$1"; }
info() { printf "${CYAN}%s${NC}\n" "$1"; }
warn() { printf "${YELLOW}%s${NC}\n" "$1"; }
err()  { printf "${RED}%s${NC}\n" "$1"; }

CONFIG="$HOME/.config/opencode/opencode.json"

check_prereqs() {
  if [ ! -f "$CONFIG" ]; then
    err "Config not found: $CONFIG"
    err "Run install-plan-it first."
    exit 1
  fi
  if ! command -v jq &>/dev/null; then
    err "jq is required. Install it first."
    exit 1
  fi
}

RESTRICTIONS='{
  "git push*": "ask",
  "git merge*": "ask",
  "git tag*": "ask",
  "rm -rf*": "ask",
  "sudo*": "ask",
  "npm publish*": "ask",
  "pip publish*": "ask",
  "docker push*": "ask",
  "docker build*": "ask",
  "kubectl apply*": "ask",
  "kubectl delete*": "ask",
  "terraform apply*": "ask",
  "terraform destroy*": "ask",
  "gh pr create*": "ask",
  "gh pr merge*": "ask",
  "systemctl*": "ask",
  "chmod -R*": "ask",
  "chown -R*": "ask",
  "mysql*": "ask",
  "psql*": "ask"
}'

install() {
  check_prereqs

  BACKUP="$CONFIG.bak.$(date +%Y%m%d%H%M%S)"
  cp "$CONFIG" "$BACKUP"
  msg "Backup saved: $BACKUP"

  jq --argjson restrictions "$RESTRICTIONS" \
    '.agent.plan.permission.bash = (.agent.plan.permission.bash // {}) * $restrictions' \
    "$BACKUP" > "$CONFIG.tmp" && mv "$CONFIG.tmp" "$CONFIG"

  msg "Restrictions installed."
  info "  Restore backup: cp $BACKUP $CONFIG"
}

uninstall() {
  check_prereqs

  BACKUP="$CONFIG.bak.$(date +%Y%m%d%H%M%S)"
  cp "$CONFIG" "$BACKUP"
  msg "Backup saved: $BACKUP"

  HAS=$(jq '.agent.plan.permission | has("bash")' "$BACKUP" 2>/dev/null || echo false)
  if [ "$HAS" != "true" ]; then
    warn "No bash restrictions found in config."
    return
  fi

  jq 'del(.agent.plan.permission.bash)' \
    "$BACKUP" > "$CONFIG.tmp" && mv "$CONFIG.tmp" "$CONFIG"

  msg "Restrictions removed."
  info "  Restore backup: cp $BACKUP $CONFIG"
}

status() {
  if [ ! -f "$CONFIG" ]; then
    err "Config not found: $CONFIG"
    exit 1
  fi

  echo ""
  info "=== Bash Restriction Status ==="
  echo ""

  HAS_BASH=$(jq '.agent.plan.permission | has("bash")' "$CONFIG" 2>/dev/null || echo false)

  if [ "$HAS_BASH" != "true" ]; then
    warn "  No bash restrictions configured."
    echo ""
    return
  fi

  jq -r '.agent.plan.permission.bash // {} | to_entries[] | "  \(.key) → \(.value)"' "$CONFIG" \
    2>/dev/null || warn "  (none)"

  echo ""
  msg "All commands above will prompt for approval before execution."
}

usage() {
  echo "Usage: $0 <command>"
  echo ""
  echo "Commands:"
  echo "  install     Install bash command restrictions"
  echo "  uninstall   Remove bash command restrictions"
  echo "  status      Show current restrictions"
  echo "  help        Show this help"
}

case "${1:-help}" in
  install)
    install
    ;;
  uninstall)
    uninstall
    ;;
  status)
    status
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
