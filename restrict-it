#!/bin/bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

OPCODE_CONFIG="$HOME/.config/opencode/opencode.json"
KILO_CONFIG="$HOME/.config/kilo/kilo.jsonc"

msg()  { printf "${GREEN}%s${NC}\n" "$1"; }
info() { printf "${CYAN}%s${NC}\n" "$1"; }
warn() { printf "${YELLOW}%s${NC}\n" "$1"; }
err()  { printf "${RED}%s${NC}\n" "$1"; }

check_prereqs() {
  if ! command -v jq &>/dev/null && ! command -v node &>/dev/null; then
    err "jq or node is required. Install one of them first."
    exit 1
  fi
}

RESTRICTIONS='{
  "git push*": "ask",
  "git merge*": "ask",
  "git tag*": "ask",
  "rm -rf*": "ask",
  "sudo*": "ask",
  "npm publish*": "ask",
  "pip publish*": "ask",
  "docker push*": "ask",
  "docker build*": "ask",
  "kubectl apply*": "ask",
  "kubectl delete*": "ask",
  "terraform apply*": "ask",
  "terraform destroy*": "ask",
  "gh pr create*": "ask",
  "gh pr merge*": "ask",
  "systemctl*": "ask",
  "chmod -R*": "ask",
  "chown -R*": "ask",
  "mysql*": "ask",
  "psql*": "ask"
}'

# ---------------------------------------------------------------------------
# Opencode (plain JSON, use jq)
# ---------------------------------------------------------------------------

install_opencode() {
  if [ ! -f "$OPCODE_CONFIG" ]; then
    err "Config not found: $OPCODE_CONFIG"
    err "Run install-plan-it first."
    exit 1
  fi
  if ! command -v jq &>/dev/null; then
    err "jq is required for opencode config management."
    exit 1
  fi

  BACKUP="$OPCODE_CONFIG.bak.$(date +%Y%m%d%H%M%S)"
  cp "$OPCODE_CONFIG" "$BACKUP"
  msg "Backup saved: $BACKUP"

  jq --argjson restrictions "$RESTRICTIONS" \
    '.agent.plan.permission.bash = (.agent.plan.permission.bash // {}) * $restrictions' \
    "$BACKUP" > "$OPCODE_CONFIG.tmp" && mv "$OPCODE_CONFIG.tmp" "$OPCODE_CONFIG"

  msg "Restrictions installed (opencode)."
  info "  Restore backup: cp $BACKUP $OPCODE_CONFIG"
}

uninstall_opencode() {
  if [ ! -f "$OPCODE_CONFIG" ]; then
    err "Config not found: $OPCODE_CONFIG"
    exit 1
  fi
  if ! command -v jq &>/dev/null; then
    err "jq is required."
    exit 1
  fi

  BACKUP="$OPCODE_CONFIG.bak.$(date +%Y%m%d%H%M%S)"
  cp "$OPCODE_CONFIG" "$BACKUP"
  msg "Backup saved: $BACKUP"

  HAS=$(jq '.agent.plan.permission | has("bash")' "$BACKUP" 2>/dev/null || echo false)
  if [ "$HAS" != "true" ]; then
    warn "No bash restrictions found in opencode config."
    return
  fi

  jq 'del(.agent.plan.permission.bash)' \
    "$BACKUP" > "$OPCODE_CONFIG.tmp" && mv "$OPCODE_CONFIG.tmp" "$OPCODE_CONFIG"

  msg "Restrictions removed (opencode)."
  info "  Restore backup: cp $BACKUP $OPCODE_CONFIG"
}

status_opencode() {
  if [ ! -f "$OPCODE_CONFIG" ]; then
    err "Config not found: $OPCODE_CONFIG"
    return
  fi
  if ! command -v jq &>/dev/null; then
    err "jq is required."
    return
  fi

  echo ""
  info "=== Bash Restriction Status (opencode) ==="
  echo ""

  HAS_BASH=$(jq '.agent.plan.permission | has("bash")' "$OPCODE_CONFIG" 2>/dev/null || echo false)
  if [ "$HAS_BASH" != "true" ]; then
    warn "  No bash restrictions configured."
    echo ""
    return
  fi

  jq -r '.agent.plan.permission.bash // {} | to_entries[] | "  \(.key) → \(.value)"' "$OPCODE_CONFIG" \
    2>/dev/null || warn "  (none)"

  echo ""
  msg "All commands above will prompt for approval before execution."
}

# ---------------------------------------------------------------------------
# Kilo (JSONC, use node to handle comments)
# ---------------------------------------------------------------------------

_kilo_node_op() {
  local operation="$1"

  local tmpf
  tmpf=$(mktemp /tmp/kilo_op_XXXXX.mjs)
  cat > "$tmpf" << 'NODEEOF'
import { readFileSync, copyFileSync, writeFileSync } from "node:fs"

const path = process.env.KILO_CONFIG_PATH
const op = process.env.KILO_OP

const restrictions = {
  "git push*": "ask",
  "git merge*": "ask",
  "git tag*": "ask",
  "rm -rf*": "ask",
  "sudo*": "ask",
  "npm publish*": "ask",
  "pip publish*": "ask",
  "docker push*": "ask",
  "docker build*": "ask",
  "kubectl apply*": "ask",
  "kubectl delete*": "ask",
  "terraform apply*": "ask",
  "terraform destroy*": "ask",
  "gh pr create*": "ask",
  "gh pr merge*": "ask",
  "systemctl*": "ask",
  "chmod -R*": "ask",
  "chown -R*": "ask",
  "mysql*": "ask",
  "psql*": "ask"
}

let content
try { content = readFileSync(path, "utf-8") } catch (e) {
  console.error("Config not found: " + path)
  process.exit(1)
}

function stripJSONC(str) {
  let out = ""
  let inStr = false, esc = false
  for (let i = 0; i < str.length; i++) {
    const c = str[i]
    if (inStr) {
      if (esc) { esc = false; out += c; continue }
      if (c === "\\") { esc = true; out += c; continue }
      if (c === '"') { inStr = false; out += c; continue }
      out += c; continue
    }
    if (c === '"') { inStr = true; out += c; continue }
    if (c === "/" && str[i+1] === "/") { while (i < str.length && str[i] !== "\n") i++; continue }
    if (c === "/" && str[i+1] === "*") { i += 2; while (i < str.length && !(str[i] === "*" && str[i+1] === "/")) i++; i++; continue }
    out += c
  }
  return out
}

const stripped = stripJSONC(content)
let config
try { config = JSON.parse(stripped) } catch (e) {
  console.error("Failed to parse JSONC: " + e.message)
  process.exit(1)
}

if (op === "install") {
  config.permission = config.permission || {}
  config.permission.bash = { ...(config.permission.bash || {}), ...restrictions }
  const backup = path + ".bak." + new Date().toISOString().replace(/[:.]/g, "")
  copyFileSync(path, backup)
  console.log("Backup saved: " + backup)
  writeFileSync(path, JSON.stringify(config, null, 2) + "\n")
  console.log("Restrictions installed (Kilo).")
  console.log("  Restore backup: cp " + backup + " " + path)

} else if (op === "uninstall") {
  if (config.permission && config.permission.bash) {
    const backup = path + ".bak." + new Date().toISOString().replace(/[:.]/g, "")
    copyFileSync(path, backup)
    console.log("Backup saved: " + backup)
    delete config.permission.bash
    if (Object.keys(config.permission).length === 0) delete config.permission
    writeFileSync(path, JSON.stringify(config, null, 2) + "\n")
    console.log("Restrictions removed (Kilo).")
    console.log("  Restore backup: cp " + backup + " " + path)
  } else {
    console.log("No bash restrictions found in Kilo config.")
  }

} else if (op === "status") {
  console.log("")
  console.log("=== Bash Restriction Status (Kilo) ===")
  console.log("")
  if (config.permission && config.permission.bash) {
    const entries = Object.entries(config.permission.bash)
    if (entries.length === 0) {
      console.log("  (none)")
    } else {
      for (const [key, val] of entries) {
        console.log("  " + key + " \u2192 " + val)
      }
    }
    console.log("")
    console.log("All commands above will prompt for approval before execution.")
  } else {
    console.log("  No bash restrictions configured.")
  }
  console.log("")
}
NODEEOF

  KILO_CONFIG_PATH="$KILO_CONFIG" KILO_OP="$operation" node "$tmpf"
  rm -f "$tmpf"
}

install_kilo() {
  if [ ! -f "$KILO_CONFIG" ]; then
    err "Config not found: $KILO_CONFIG"
    err "Run 'kilo' at least once to generate it."
    exit 1
  fi
  if ! command -v node &>/dev/null; then
    err "node is required for Kilo JSONC config management."
    exit 1
  fi
  _kilo_node_op "install"
}

uninstall_kilo() {
  if [ ! -f "$KILO_CONFIG" ]; then
    err "Config not found: $KILO_CONFIG"
    exit 1
  fi
  if ! command -v node &>/dev/null; then
    err "node is required."
    exit 1
  fi
  _kilo_node_op "uninstall"
}

status_kilo() {
  if [ ! -f "$KILO_CONFIG" ]; then
    err "Config not found: $KILO_CONFIG"
    return
  fi
  if ! command -v node &>/dev/null; then
    err "node is required."
    return
  fi
  _kilo_node_op "status"
}

# ---------------------------------------------------------------------------
# Usage / dispatch
# ---------------------------------------------------------------------------

usage() {
  echo "Usage: $0 <command> [<cli>]"
  echo ""
  echo "Commands:"
  echo "  enable <cli>      Add bash command restrictions (kilo|opencode)"
  echo "  disable <cli>     Remove bash command restrictions (kilo|opencode)"
  echo "  status [<cli>]    Show current restrictions (kilo|opencode|all)"
  echo ""
  echo "Examples:"
  echo "  $0 enable kilo"
  echo "  $0 disable opencode"
  echo "  $0 status"
  echo "  $0 status kilo"
}

case "${1:-help}" in
  enable)
    check_prereqs
    case "${2:-}" in
      kilo) install_kilo ;;
      opencode) install_opencode ;;
      *) err "Usage: $0 enable <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  disable)
    case "${2:-}" in
      kilo) uninstall_kilo ;;
      opencode) uninstall_opencode ;;
      *) err "Usage: $0 disable <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  status)
    case "${2:-all}" in
      kilo) status_kilo ;;
      opencode) status_opencode ;;
      all|"") status_kilo; status_opencode ;;
      *) err "Usage: $0 status [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
