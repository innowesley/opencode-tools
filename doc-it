8. **TRACEABILITY** — Run `traceability-generator` to refresh the feature map
9. **AI CONTEXT** — Run `ai-context-generator` to refresh project memory
10. **VIOLATIONS** — Run `rule-violation-checker` to verify no new violations
11. **COMPLETE** — Archive plan with edit+mv (prepend completion timestamp, then mv to `.agents/plans/completed/`)

Tasks FAIL if any doc step is skipped.
AGENTS_BLOCK
)
  replace_managed_block "$dir/AGENTS.md" "$DOCIT_BEGIN" "$DOCIT_END" "$agents_block"
  msg "AGENTS.md updated (Kilo) → $dir/AGENTS.md"
}

# ---------------------------------------------------------------------------
# Project init (shared)
# ---------------------------------------------------------------------------

init_project() {
  local cli="$1"
  local dir="$2"
  mkdir -p "$dir"
  msg "Initializing doc-it in project: $dir"

  mkdir -p "$dir/docs/$DOCS_TREE_BRACE" "$dir/.ai"

  create_docs "$dir"
  create_ai_rules "$dir"

  case "$cli" in
    kilo)
      mkdir -p "$dir/.kilo/plans" "$dir/.agents/plans/pending" "$dir/.agents/plans/completed"
      install_agents_md_kilo "$dir"
      ;;
    opencode|none)
      mkdir -p "$dir/.opencode/plans" "$dir/.opencode/tools" \
        "$dir/.agents/plans/pending" "$dir/.agents/plans/completed"
      if [ -d "$OPCODE_CONFIG_DIR/tools" ]; then
        for f in "$OPCODE_CONFIG_DIR/tools"/*.ts; do
          [ -f "$f" ] || continue
          safe_cp_tool "$f" "$dir/.opencode/tools/$(basename "$f")"
        done
      fi
      install_agents_md_opencode "$dir"
      ;;
  esac

  msg "Project init complete → $dir"
}

# ---------------------------------------------------------------------------
# Uninstall
# ---------------------------------------------------------------------------

uninstall_opencode() {
  warn "Uninstalling doc-it (opencode)..."

  if [ -f "$OPCODE_MANIFEST" ]; then
    node -e "
      const fs = require('fs');
      const m = JSON.parse(fs.readFileSync('$OPCODE_MANIFEST', 'utf-8'));
      for (const f of m.files) {
        if (f.ownership === 'user') continue;
        try {
          fs.unlinkSync(f.path);
          console.log('  Removed: ' + f.path);
        } catch (e) {
          if (e.code !== 'ENOENT') console.error('  Error removing ' + f.path + ': ' + e.message);
        }
      }
    "
    rm -f "$OPCODE_MANIFEST"
  else
    for f in doc-drift-checker.ts changelog-generator.ts traceability-generator.ts ai-context-generator.ts rule-violation-checker.ts; do
      [ -f "$OPCODE_CONFIG_DIR/tools/$f" ] && rm "$OPCODE_CONFIG_DIR/tools/$f" && info "  Removed: $f"
    done
  fi

  safe_rmdir "$OPCODE_CONFIG_DIR/tools"

  warn "Note: docs/ tree and AGENTS.md hooks in projects must be removed manually."
  msg "Global uninstall complete"
}

uninstall_kilo() {
  warn "Uninstalling doc-it (Kilo)..."

  if [ -f "$KILO_MANIFEST" ]; then
    node -e "
      const fs = require('fs');
      const m = JSON.parse(fs.readFileSync('$KILO_MANIFEST', 'utf-8'));
      for (const f of m.files) {
        if (f.ownership === 'user') continue;
        try {
          const stat = fs.statSync(f.path);
          if (stat.isDirectory()) {
            fs.rmSync(f.path, { recursive: true, force: true });
          } else {
            fs.unlinkSync(f.path);
          }
          console.log('  Removed: ' + f.path);
        } catch (e) {
          if (e.code !== 'ENOENT') console.error('  Error removing ' + f.path + ': ' + e.message);
        }
      }
    "
    rm -f "$KILO_MANIFEST"
  else
    if [ -f "$KILO_PLUGIN_DIR/dist/doc-it.js" ]; then
      rm "$KILO_PLUGIN_DIR/dist/doc-it.js"
      info "  Removed: $KILO_PLUGIN_DIR/dist/doc-it.js"
    fi
  fi

  warn "Note: docs/ tree and AGENTS.md hooks in projects must be removed manually."
  msg "Kilo uninstall complete"
}

