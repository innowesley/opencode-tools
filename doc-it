install_project() {
  local cli="$1"
  local dir="$2"
  mkdir -p "$dir"
  msg "Initializing doc-it in project: $dir"

  mkdir -p $dir/$DOCS_TREE $dir/.ai

  create_docs "$dir"

  case "$cli" in
    kilo)
      mkdir -p "$dir/.kilo/plans" "$dir/.agents/plans/pending" "$dir/.agents/plans/completed"
      install_agents_md_kilo "$dir"
      ;;
    opencode|none)
      if [ -d "$OPCODE_CONFIG_DIR/tools" ]; then
        cp "$OPCODE_CONFIG_DIR/tools"/*.ts "$dir/.opencode/tools/" 2>/dev/null || true
      fi
      mkdir -p "$dir/.opencode/plans" "$dir/.agents/plans/pending" "$dir/.agents/plans/completed"
      install_agents_md_opencode "$dir"
      ;;
  esac

  msg "Project init complete → $dir"
}

