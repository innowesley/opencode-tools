# ---------------------------------------------------------------------------
# Doctor
# ---------------------------------------------------------------------------

doctor_opencode() {
  echo ""
  info "=== doc-it doctor (opencode) v$VERSION ==="
  echo ""

  local errors=0
  local warnings=0

  if [ -f "$OPCODE_MANIFEST" ]; then
    msg "  \u2705 Manifest present"
  else
    warn "  \u2b1c No manifest"
    warnings=$((warnings + 1))
  fi

  for f in doc-drift-checker.ts changelog-generator.ts traceability-generator.ts ai-context-generator.ts rule-violation-checker.ts; do
    local fp="$OPCODE_CONFIG_DIR/tools/$f"
    if [ -f "$fp" ]; then
      if head -3 "$fp" | grep -q "doc-it-managed: true"; then
        msg "  \u2705 $f (managed)"
      else
        warn "  \u26a0 $f (user-modified or missing managed header)"
        warnings=$((warnings + 1))
      fi
    else
      err "  \u274c $f missing"
      errors=$((errors + 1))
    fi
  done

  echo ""
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    msg "doc-it (opencode): healthy"
  elif [ "$errors" -eq 0 ]; then
    warn "doc-it (opencode): $warnings warning(s)"
  else
    err "doc-it (opencode): $errors error(s), $warnings warning(s)"
  fi
  echo ""
  return "$errors"
}

doctor_kilo() {
  echo ""
  info "=== doc-it doctor (Kilo) v$VERSION ==="
  echo ""

  local errors=0
  local warnings=0

  if [ -f "$KILO_PLUGIN_DIR/dist/doc-it.js" ]; then
