    warn "  ⬜ Plugin not registered in kilo.jsonc"
  fi

  echo ""
  msg "doc-it (Kilo) status complete"
  echo ""
}

# ---------------------------------------------------------------------------
# Usage / dispatch
# ---------------------------------------------------------------------------

usage() {
  echo "Usage: $0 <command> [<cli>] [<project-dir>]"
  echo ""
  echo "Commands:"
  echo "  install <cli>              Install doc-it tools (kilo|opencode)"
  echo "  install <cli> <project>    Install + initialize project"
  echo "  uninstall <cli>            Remove doc-it tools (kilo|opencode)"
  echo "  status [<cli>]             Show installed components (kilo|opencode|all)"
  echo ""
  echo "Examples:"
  echo "  $0 install kilo"
  echo "  $0 install opencode"
  echo "  $0 install opencode ./my-project"
  echo "  $0 uninstall kilo"
  echo "  $0 status"
  echo "  $0 status opencode"
  echo ""
  echo "Aliases: add = install, rm = uninstall"
}

case "${1:-help}" in
  install|add)
    case "${2:-}" in
      kilo)
        install_kilo_global
        if [ -n "${3:-}" ]; then install_project kilo "$3"; fi
        ;;
      opencode)
        install_opencode_global
        if [ -n "${3:-}" ]; then install_project opencode "$3"; fi
        ;;
      *) err "Usage: $0 install <kilo|opencode> [project-dir]"; exit 1 ;;
    esac
    ;;
  uninstall|rm)
    case "${2:-}" in
      kilo) uninstall_kilo ;;
      opencode) uninstall_opencode ;;
      *) err "Usage: $0 uninstall <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  status)
    case "${2:-all}" in
      kilo) show_status_kilo ;;
      opencode) show_status_opencode ;;
      all|"") show_status_kilo; show_status_opencode ;;
      *) err "Usage: $0 status [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
