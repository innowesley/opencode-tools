#!/bin/bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

OPCODE_CONFIG_DIR="$HOME/.config/opencode"
KILO_CONFIG_DIR="$HOME/.config/kilo"
KILO_PLUGIN_DIR="$KILO_CONFIG_DIR/node_modules/@opencode-tools/kilo-plugin"

DOCS_TREE="docs/ai-context docs/architecture docs/features docs/database docs/api docs/testing docs/decisions docs/changelogs docs/generated docs/audits docs/contracts docs/playbooks docs/known-issues docs/future/technical-debt docs/future/architecture-improvements docs/future/ai-improvements docs/future/feature-ideas docs/future/rejected-ideas"

msg()  { printf "${GREEN}%s${NC}\n" "$1"; }
info() { printf "${CYAN}%s${NC}\n" "$1"; }
warn() { printf "${YELLOW}%s${NC}\n" "$1"; }
err()  { printf "${RED}%s${NC}\n" "$1"; }

