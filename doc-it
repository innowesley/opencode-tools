install_opencode_tools() {
  command -v node >/dev/null 2>&1 || { err "node is required but not installed"; return 1; }
  command -v npm >/dev/null 2>&1 || { err "npm is required but not installed"; return 1; }
  local tdir="$1"

  # --- Shared core module (framework-agnostic) ---
  cat > "$tdir/doc-it-core.js" << 'COREEOF'
// doc-it-managed: true
// source-version: 1.0.0
import { readdir, readFile, stat, mkdir, writeFile } from "node:fs/promises"

async function getRecentlyChanged(base) {
  try {
    const { execSync } = await import("node:child_process")
    const out = execSync("git diff --name-only HEAD~1..HEAD 2>/dev/null || git diff --name-only 2>/dev/null || echo", { cwd: base, encoding: "utf-8" })
    return out.trim().split("\n").filter(Boolean)
  } catch {
    console.warn("doc-drift-checker: not a git repository or git unavailable; falling back to full src/ scan")
    return ["src/"]
  }
}

async function walkDocs(dir, prefix) {
  const entries = await readdir(dir, { withFileTypes: true })
  const results = []
  for (const entry of entries) {
    if (entry.isDirectory()) {
      const sub = await walkDocs(dir + "/" + entry.name, prefix ? prefix + "/" + entry.name : entry.name)
      results.push(...sub)
    } else if (entry.name.endsWith(".md")) {
      results.push(prefix ? prefix + "/" + entry.name : entry.name)
    }
  }
  return results
}

async function listDocs(dir) {
  try {
    return await walkDocs(dir, "")
  } catch {
    return []
  }
}

function parseYamlList(frontmatter, key) {
  const re = new RegExp("^" + key + ":\\s*((?:\\n\\s+-\\s+.*)+)", "m")
  const m = frontmatter.match(re)
  if (m) return m[1].trim().split("\n").map(s => s.replace(/^\s*-\s*/, "").trim())
  const inline = frontmatter.match(new RegExp("^" + key + ":\\s*\\[([^\\]]+)\\]", "m"))
  if (inline) return inline[1].split(",").map(s => s.trim().replace(/^['"]|['"]$/g, ""))
  const flat = frontmatter.match(new RegExp("^" + key + ":\\s*(.+)$", "m"))
  return flat ? flat[1].split(",").map(s => s.trim()) : []
}

async function scanDirForPatterns(dir, violations, patterns) {
  try {
    const entries = await readdir(dir, { withFileTypes: true })
    for (const entry of entries) {
      const full = dir + "/" + entry.name
      if (entry.isDirectory() && !entry.name.startsWith(".") && entry.name !== "node_modules") {
        await scanDirForPatterns(full, violations, patterns)
      } else if (entry.isFile() && (entry.name.endsWith(".ts") || entry.name.endsWith(".js"))) {
        const content = await readFile(full, "utf-8")
        for (const p of patterns) {
          if (content.match(p.pattern)) {
            violations.push({ rule: p.rule, file: full, severity: p.severity })
          }
        }
      }
    }
  } catch { console.warn("doc-it: error scanning " + dir + " for forbidden patterns") }
}

async function scanDirForRoutes(dir, apiDoc, violations) {
  try {
    const entries = await readdir(dir, { withFileTypes: true })
    for (const entry of entries) {
      const full = dir + "/" + entry.name
      if (entry.isDirectory() && !entry.name.startsWith(".") && entry.name !== "node_modules") {
        await scanDirForRoutes(full, apiDoc, violations)
      } else if (entry.isFile() && (entry.name.endsWith(".ts") || entry.name.endsWith(".js"))) {
        const content = await readFile(full, "utf-8")
        const routeDefs = content.match(/(?:app|router)\s*(?:\.route\([^)]+\))?\s*\.(?:get|post|put|patch|delete|options)\(['"`][^'"`]+/g)
        if (routeDefs) {
          for (const r of routeDefs) {
            if (!apiDoc.includes(r)) {
              violations.push({ rule: "Route " + r + " not documented in api-registry.md", file: full, severity: "medium" })
            }
          }
        }
      }
    }
  } catch { console.warn("doc-it: error scanning " + dir + " for routes") }
}

export async function checkDocDrift(args, base) {
  const stale = []
  let healthy = 0
  const changedFiles = args.changedFiles ? args.changedFiles.split(",").map(s => s.trim()) : await getRecentlyChanged(base)
  const featureDocs = await listDocs(base + "/docs/features")
  const apiDocs = await listDocs(base + "/docs/api")
  const dbDocs = await listDocs(base + "/docs/database")

  for (const file of changedFiles) {
    if (file.startsWith("docs/")) continue
    if ((file.includes("/routes/") || file.match(/\.route\./)) && apiDocs.length === 0) {
      stale.push({ doc: "docs/api/api-registry.md", reason: "Route file changed (" + file + ") but no API docs found", severity: "important" }); continue
    }
    if (file.match(/schema|model|migration|\.sql/) && dbDocs.length === 0) {
      stale.push({ doc: "docs/database/schema-overview.md", reason: "Schema file changed (" + file + ") but no DB docs found", severity: "critical" }); continue
    }
    if (file.match(/src\/(features|modules|components)/)) {
      const featureName = file.split("/").slice(2, 3).join("/")
      if (!featureDocs.find(f => f.includes(featureName))) {
        stale.push({ doc: "docs/features/" + featureName + "/", reason: "Feature file changed (" + file + ") but no feature docs found", severity: "important" })
      }
    }
  }

  for (const docs of [featureDocs, apiDocs, dbDocs]) {
    for (const doc of docs) {
      try {
        const content = await readFile(base + "/" + doc, "utf-8")
        const refs = content.match(/(?:`)?[\w./-]+\.\w{1,4}(?:`)?/g) || []
        for (const ref of refs) {
          const clean = ref.replace(/`/g, "")
          if ((clean.startsWith(".") || clean.startsWith("/") || clean.includes("/")) && !clean.startsWith("http")) {
            try { await stat(base + "/" + clean) } catch {
              if (!stale.find(s => s.doc === doc)) stale.push({ doc, reason: "Referenced file " + clean + " no longer exists", severity: "important" })
            }
          }
        }
        healthy++
      } catch { healthy++ }
    }
  }
  return JSON.stringify({ count: changedFiles.length, stale, healthy_count: healthy })
}

export async function createChangelog(args, base) {
  const changelogDir = base + "/docs/changelogs"
  await mkdir(changelogDir, { recursive: true })
  const date = new Date().toISOString().split("T")[0]
  const slug = args.title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")
  const filename = date + "-" + slug + ".md"
  const fullPath = changelogDir + "/" + filename
  const header = "<!-- GENERATED FILE -- DO NOT EDIT -->\n<!-- generator: doc-it changelog-generator -->\n<!-- source: changelog-generator.ts -->\n<!-- generated-at: " + new Date().toISOString() + " -->\n\n"
  const content = "# " + date + " \u2014 " + args.title + "\n\n" + args.changes + (args.features ? "\n\n**Affected features:** " + args.features : "") + (args.breaking ? "\n\n## Breaking Changes\n\n" + args.breaking : "") + "\n"
  await writeFile(fullPath, header + content, "utf-8")
  return JSON.stringify({ changelog: "docs/changelogs/" + filename, path: fullPath })
}

export async function buildTraceability(base) {
  const archDir = base + "/docs/architecture/generated"
  await mkdir(archDir, { recursive: true })
  const featureDocsDir = base + "/docs/features"
  const traceability = []

  try {
    const entries = await readdir(featureDocsDir, { withFileTypes: true })
    for (const entry of entries) {
      if (!entry.name.endsWith(".md")) continue
      const content = await readFile(featureDocsDir + "/" + entry.name, "utf-8")
      const frontmatter = content.match(/^---\n([\s\S]*?)\n---/)?.[1] || ""
      traceability.push({
        feature: entry.name.replace(/\.md$/, ""),
        files: parseYamlList(frontmatter, "source_dirs"),
        routes: parseYamlList(frontmatter, "related_routes"),
        tables: parseYamlList(frontmatter, "related_tables"),
        tests: parseYamlList(frontmatter, "testing_workflows"),
        docs: [entry.name]
      })
    }
  } catch {}

  let rows = ""
  for (const t of traceability) {
    rows += "| " + t.feature + " | " + (t.files.join(", ") || "\u2014") + " | " + (t.routes.join(", ") || "\u2014") + " | " + (t.tables.join(", ") || "\u2014") + " | " + (t.tests.join(", ") || "\u2014") + " | " + (t.docs.join(", ") || "\u2014") + " |\n"
  }

  const timestamp = new Date().toISOString()
  const mapContent = "<!-- GENERATED FILE -- DO NOT EDIT -->\n<!-- generator: doc-it traceability-generator -->\n<!-- source: traceability-generator.ts -->\n<!-- generated-at: " + timestamp + " -->\n\n# Traceability Map\n\n_Generated: " + timestamp + "_\n\n| Feature | Files | Routes | Tables | Tests | Docs |\n|---------|-------|--------|--------|-------|------|\n" + rows + "\n## Summary\n\n- **Features tracked:** " + traceability.length + "\n- **Total routes:** " + traceability.reduce((a, t) => a + t.routes.length, 0) + "\n- **Total tables:** " + traceability.reduce((a, t) => a + t.tables.length, 0) + "\n"
  await writeFile(archDir + "/traceability.md", mapContent, "utf-8")
  return JSON.stringify({ traceability_count: traceability.length, path: "docs/architecture/generated/traceability.md" })
}

export async function generateAiContext(base) {
  const aiGenDir = base + "/docs/ai-context/generated"
  const archDir = base + "/docs/architecture"
  const featuresDir = base + "/docs/features"
  const knownDir = base + "/docs/known-issues"
  await mkdir(aiGenDir, { recursive: true })
  const sections = []

  const readSection = async (dir) => {
    const lines = []
    try {
      const files = await readdir(dir)
      for (const f of files) {
        if (!f.endsWith(".md")) continue
        const content = await readFile(dir + "/" + f, "utf-8")
        const h1 = content.match(/^# (.+)/m)?.[1] || f.replace(/\.md$/, "")
        lines.push("\n### " + h1 + "\n" + content.slice(0, 500).replace(/^#.+$/m, "").trim() + "\n")
      }
    } catch {}
    return lines
  }

  sections.push("## Architecture\n" + (await readSection(archDir)).join("\n"))
  sections.push("## Features\n" + (await readSection(featuresDir)).join("\n"))
  sections.push("## Known Issues\n" + (await readSection(knownDir)).join("\n"))

  const timestamp = new Date().toISOString()
  const stateContent = "<!-- GENERATED FILE -- DO NOT EDIT -->\n<!-- generator: doc-it ai-context-generator -->\n<!-- source: ai-context-generator.ts -->\n<!-- generated-at: " + timestamp + " -->\n\n# Current System State\n\n_Last regenerated: " + timestamp + "_\n\n" + sections.join("\n") + "\n"
  await writeFile(aiGenDir + "/current-system-state.md", stateContent, "utf-8")
  const summaryContent = "<!-- GENERATED FILE -- DO NOT EDIT -->\n<!-- generator: doc-it ai-context-generator -->\n<!-- source: ai-context-generator.ts -->\n<!-- generated-at: " + timestamp + " -->\n\n# Project Summary\n\n_Generated: " + timestamp + "_\n\n" + sections.slice(0, 2).join("\n") + (knownDir ? "\n### Known Issues (" + sections[2].length + ")\n- See docs/known-issues/" : "") + "\n"
  await writeFile(aiGenDir + "/project-summary.md", summaryContent, "utf-8")
  return JSON.stringify({ regenerated: ["docs/ai-context/generated/current-system-state.md", "docs/ai-context/generated/project-summary.md"], sections_compressed: sections.length })
}

const forbiddenPatterns = [
  { pattern: /db\.\w+\.\s*(create|update|delete|upsert)/g, rule: "Direct DB write (use service layer)", severity: "high" },
  { pattern: /prisma\.\w+\.\s*(create|update|delete|upsert)/g, rule: "Direct Prisma write (use service layer)", severity: "high" },
  { pattern: /await\s+\w+\s*\.\s*save\s*\(/g, rule: "Direct entity save (use repository)", severity: "medium" },
]

export async function checkRuleViolations(sourceDirs, base) {
  const violations = []
  let passed = 0
  for (const dir of sourceDirs) {
    await scanDirForPatterns(base + "/" + dir, violations, forbiddenPatterns)
  }
  let contractFiles = []
  try { contractFiles = (await readdir(base + "/docs/contracts")).filter(f => f.endsWith(".md")) } catch {}
  for (const cf of contractFiles) {
    try {
      const content = await readFile(base + "/docs/contracts/" + cf, "utf-8")
      if (content.match(/## Forbidden/)) passed++
    } catch {}
  }
  let apiDoc = ""
  try { apiDoc = await readFile(base + "/docs/api/api-registry.md", "utf-8") } catch {}
  for (const dir of sourceDirs) {
    await scanDirForRoutes(base + "/" + dir, apiDoc, violations)
  }
  return JSON.stringify({ violations, passed_checks: passed + (apiDoc ? 1 : 0) })
}
