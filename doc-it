# ---------------------------------------------------------------------------
# Usage / dispatch
# ---------------------------------------------------------------------------

usage() {
  echo "Usage: $0 [--restore-seeds] <command> [<cli>] [<project-dir>]"
  echo ""
  echo "Global flags:"
  echo "  --restore-seeds            Overwrite existing seed files during init"
  echo ""
  echo "Commands:"
  echo "  install <cli>              Install doc-it tools globally (kilo|opencode)"
  echo "  init <cli> <project>       Initialize project docs structure"
  echo "  uninstall <cli>            Remove doc-it tools (kilo|opencode)"
  echo "  status [<cli>]             Show installed components (kilo|opencode|all)"
  echo "  doctor [<cli>]             Read-only diagnostics (kilo|opencode|all)"
  echo ""
  echo "Examples:"
  echo "  $0 install kilo"
  echo "  $0 install opencode"
  echo "  $0 init opencode ./my-project"
  echo "  $0 --restore-seeds init opencode ./my-project"
  echo "  $0 uninstall kilo"
  echo "  $0 status"
  echo "  $0 doctor"
  echo "  $0 doctor opencode"
  echo ""
  echo "Aliases: add = install, rm = uninstall"
}

RESTORE_SEEDS=
if [ "${1:-}" = "--restore-seeds" ]; then
  RESTORE_SEEDS=1
  export RESTORE_SEEDS
  shift
  msg "--restore-seeds: Will overwrite existing seed files"
fi

case "${1:-help}" in
  install|add)
    case "${2:-}" in
      kilo)
        install_kilo_global
        if [ -n "${3:-}" ]; then
          warn "'install <cli> <project>' is deprecated. Use 'init <cli> <project>'"
          init_project kilo "$3"
        fi
        ;;
      opencode)
        install_opencode_global
        if [ -n "${3:-}" ]; then
          warn "'install <cli> <project>' is deprecated. Use 'init <cli> <project>'"
          init_project opencode "$3"
        fi
        ;;
      *) err "Usage: $0 install <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  init)
    case "${2:-}" in
      kilo) init_project kilo "${3:-.}" ;;
      opencode|none) init_project opencode "${3:-.}" ;;
      *) err "Usage: $0 init <kilo|opencode> [project-dir]"; exit 1 ;;
    esac
    ;;
  uninstall|rm)
    case "${2:-}" in
      kilo) uninstall_kilo ;;
      opencode) uninstall_opencode ;;
      *) err "Usage: $0 uninstall <kilo|opencode>"; exit 1 ;;
    esac
    ;;
  status)
    case "${2:-all}" in
      kilo) show_status_kilo ;;
      opencode) show_status_opencode ;;
      all|"") show_status_kilo; show_status_opencode ;;
      *) err "Usage: $0 status [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  doctor)
    case "${2:-all}" in
      kilo) doctor_kilo ;;
      opencode) doctor_opencode ;;
      all|"") doctor_kilo; doctor_opencode ;;
      *) err "Usage: $0 doctor [kilo|opencode|all]"; exit 1 ;;
    esac
    ;;
  help|--help|-h)
    usage
    ;;
  upgrade)
    msg "Upgrade not yet implemented. Re-run 'install' to refresh managed assets."
    ;;
  repair)
    warn "repair not yet implemented. Use 'doctor' to check status."
    ;;
  *)
    err "Unknown command: $1"
    usage
    exit 1
    ;;
esac
