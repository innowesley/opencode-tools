# Uninstall
# ---------------------------------------------------------------------------

uninstall_opencode() {
  warn "Uninstalling doc-it (opencode)..."

  for f in doc-drift-checker.ts changelog-generator.ts traceability-generator.ts ai-context-generator.ts rule-violation-checker.ts; do
    if [ -f "$OPCODE_CONFIG_DIR/tools/$f" ]; then
      rm "$OPCODE_CONFIG_DIR/tools/$f"
      info "  Removed: $OPCODE_CONFIG_DIR/tools/$f"
    fi
  done

  rmdir "$OPCODE_CONFIG_DIR/tools" 2>/dev/null || true

  warn "Note: docs/ tree and AGENTS.md hooks in projects must be removed manually."
  msg "Global uninstall complete"
}

uninstall_kilo() {
  warn "Uninstalling doc-it (Kilo)..."

  if [ -f "$KILO_PLUGIN_DIR/dist/doc-it.js" ]; then
    rm "$KILO_PLUGIN_DIR/dist/doc-it.js"
    info "  Removed: $KILO_PLUGIN_DIR/dist/doc-it.js"
  fi

  warn "Note: docs/ tree and AGENTS.md hooks in projects must be removed manually."
  msg "Kilo uninstall complete"
}

