install_opencode_tools() {
  local tdir="$1"

  cat > "$tdir/doc-drift-checker.ts" << 'TOOLEOF'
import { readdir, readFile, stat } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

export default tool({
  description: "Check for stale/missing documentation by scanning changed source files and cross-referencing with docs/",
  args: {
    changedFiles: tool.schema.string().optional().describe("Comma-separated list of changed files (auto-detected if not provided)"),
  },
  async execute(args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const stale: { doc: string; reason: string; severity: string }[] = []
    let healthy = 0

    const changedFiles = args.changedFiles
      ? args.changedFiles.split(",").map(s => s.trim())
      : await getRecentlyChanged(base)

    const featureDocs = await listDocs(`${base}/docs/features`)
    const apiDocs = await listDocs(`${base}/docs/api`)
    const dbDocs = await listDocs(`${base}/docs/database`)

    for (const file of changedFiles) {
      if (file.startsWith("docs/")) continue

      if ((file.includes("/routes/") || file.match(/\.route\./)) && apiDocs.length === 0) {
        stale.push({ doc: "docs/api/api-registry.md", reason: `Route file changed (${file}) but no API docs found`, severity: "important" })
        continue
      }

      if (file.match(/schema|model|migration|\.sql/) && dbDocs.length === 0) {
        stale.push({ doc: "docs/database/schema-overview.md", reason: `Schema file changed (${file}) but no DB docs found`, severity: "critical" })
        continue
      }

      if (file.match(/src\/(features|modules|components)/)) {
        const featureName = file.split("/").slice(2, 3).join("/")
        const matchingFeature = featureDocs.find(f => f.includes(featureName))
        if (!matchingFeature) {
          stale.push({ doc: `docs/features/${featureName}/`, reason: `Feature file changed (${file}) but no feature docs found`, severity: "important" })
        }
      }
    }

    for (const docs of [featureDocs, apiDocs, dbDocs]) {
      for (const doc of docs) {
        try {
          const content = await readFile(`${base}/${doc}`, "utf-8")
          const refs = content.match(/(?:`)?[\w./-]+\.\w{1,4}(?:`)?/g) || []
          for (const ref of refs) {
            const clean = ref.replace(/`/g, "")
            if ((clean.startsWith(".") || clean.startsWith("/") || clean.includes("/")) && !clean.startsWith("http")) {
              try { await stat(`${base}/${clean}`) } catch {
                if (!stale.find(s => s.doc === doc)) {
                  stale.push({ doc, reason: `Referenced file ${clean} no longer exists`, severity: "important" })
                }
              }
            }
          }
          healthy++
        } catch { healthy++ }
      }
    }

    return JSON.stringify({ count: changedFiles.length, stale, healthy_count: healthy })
  },
})

async function getRecentlyChanged(base: string): Promise<string[]> {
  try {
    const { execSync } = await import("node:child_process")
    const out = execSync("git diff --name-only HEAD~1..HEAD 2>/dev/null || git diff --name-only 2>/dev/null || echo", { cwd: base, encoding: "utf-8" })
    return out.trim().split("\n").filter(Boolean)
  } catch {
    return ["src/"]
  }
}

async function listDocs(dir: string): Promise<string[]> {
  try {
    const files = await readdir(dir, { recursive: true }) as string[]
    return files.filter(f => f.endsWith(".md")).map(f => `docs/${dir.split("/docs/")[1]}/${f}`)
  } catch {
    return []
  }
}
TOOLEOF

  cat > "$tdir/changelog-generator.ts" << 'TOOLEOF'
import { mkdir, writeFile } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

export default tool({
  description: "Create a changelog entry in docs/changelogs/",
  args: {
    title: tool.schema.string().describe("Short title for the changelog entry"),
    changes: tool.schema.string().describe("Markdown list of changes made"),
    breaking: tool.schema.string().optional().describe("Any breaking changes (omit if none)"),
    features: tool.schema.string().optional().describe("Feature names affected, comma-separated"),
  },
  async execute(args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const changelogDir = `${base}/docs/changelogs`
    await mkdir(changelogDir, { recursive: true })

    const date = new Date().toISOString().split("T")[0]
    const slug = args.title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")
    const filename = `${date}-${slug}.md`
    const fullPath = `${changelogDir}/${filename}`

    const content = `# ${date} — ${args.title}\n\n${args.changes}\n${args.features ? `\n**Affected features:** ${args.features}` : ""}${args.breaking ? `\n\n## Breaking Changes\n\n${args.breaking}` : ""}\n`

    await writeFile(fullPath, content, "utf-8")
    return JSON.stringify({ changelog: `docs/changelogs/${filename}`, path: fullPath })
  },
})
TOOLEOF

  cat > "$tdir/traceability-generator.ts" << 'TOOLEOF'
import { readdir, readFile, writeFile, mkdir } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

export default tool({
  description: "Build a feature → files → routes → tables → tests → docs traceability map in docs/architecture/traceability.md",
  args: {},
  async execute(_args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const archDir = `${base}/docs/architecture`
    await mkdir(archDir, { recursive: true })

    const featureDocsDir = `${base}/docs/features`
    const traceability: { feature: string; files: string[]; routes: string[]; tables: string[]; tests: string[]; docs: string[] }[] = []

    try {
      const entries = await readdir(featureDocsDir, { withFileTypes: true })
      for (const entry of entries) {
        if (!entry.name.endsWith(".md")) continue
        const content = await readFile(`${featureDocsDir}/${entry.name}`, "utf-8")
        const feature = entry.name.replace(/\.md$/, "")

        const files = content.match(/source_dirs:\s*([^\n]+)/)?.[1].split(",").map(s => s.trim().replace(/^- /, "")) || []
        const routes = content.match(/related_routes:\s*([^\n]+)/)?.[1].split(",").map(s => s.trim().replace(/^- /, "")) || []
        const tables = content.match(/related_tables:\s*([^\n]+)/)?.[1].split(",").map(s => s.trim().replace(/^- /, "")) || []
        const tests = content.match(/testing_workflows:\s*([^\n]+)/)?.[1].split(",").map(s => s.trim().replace(/^- /, "")) || []

        traceability.push({ feature, files, routes, tables, tests, docs: [entry.name] })
      }
    } catch {}

    let rows = ""
    for (const t of traceability) {
      rows += `| ${t.feature} | ${t.files.join(", ") || "—"} | ${t.routes.join(", ") || "—"} | ${t.tables.join(", ") || "—"} | ${t.tests.join(", ") || "—"} | ${t.docs.join(", ") || "—"} |\n`
    }

    const mapContent = `# Traceability Map\n\n_Generated: ${new Date().toISOString()}_\n\n| Feature | Files | Routes | Tables | Tests | Docs |\n|---------|-------|--------|--------|-------|------|\n${rows}\n## Summary\n\n- **Features tracked:** ${traceability.length}\n- **Total routes:** ${traceability.reduce((a, t) => a + t.routes.length, 0)}\n- **Total tables:** ${traceability.reduce((a, t) => a + t.tables.length, 0)}\n`

    await writeFile(`${archDir}/traceability.md`, mapContent, "utf-8")
    return JSON.stringify({ traceability_count: traceability.length, path: "docs/architecture/traceability.md" })
  },
})
TOOLEOF

  cat > "$tdir/ai-context-generator.ts" << 'TOOLEOF'
import { readdir, readFile, writeFile, mkdir } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

export default tool({
  description: "Regenerate ai-context docs (current-system-state.md + project-summary.md) from the project docs tree",
  args: {},
  async execute(_args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const aiDir = `${base}/docs/ai-context`
    const archDir = `${base}/docs/architecture`
    const featuresDir = `${base}/docs/features`
    const knownDir = `${base}/docs/known-issues`

    await mkdir(aiDir, { recursive: true })

    const sections: string[] = []

    const readSection = async (dir: string, title: string): Promise<string[]> => {
      const lines: string[] = []
      try {
        const files = await readdir(dir)
        for (const f of files) {
          if (!f.endsWith(".md")) continue
          const content = await readFile(`${dir}/${f}`, "utf-8")
          const h1 = content.match(/^# (.+)/m)?.[1] || f.replace(/\.md$/, "")
          lines.push(`\n### ${h1}\n${content.slice(0, 500).replace(/^#.+$/m, "").trim()}\n`)
        }
      } catch {}
      return lines
    }

    const archLines = await readSection(archDir, "Architecture")
    sections.push(`## Architecture\n${archLines.join("\n")}`)

    const featureLines = await readSection(featuresDir, "Features")
    sections.push(`## Features\n${featureLines.join("\n")}`)

    const knownLines = await readSection(knownDir, "Known Issues")
    sections.push(`## Known Issues\n${knownLines.join("\n")}`)

    let aiContext = ""
    try { aiContext = await readFile(`${aiDir}/business-rules.md`, "utf-8") } catch {}

    const stateContent = `# Current System State\n\n_Last regenerated: ${new Date().toISOString()}_\n\n${sections.join("\n")}${aiContext ? `\n## Business Rules\n${aiContext}` : ""}\n`
    await writeFile(`${aiDir}/current-system-state.md`, stateContent, "utf-8")

    const summaryContent = `# Project Summary\n\n_Generated: ${new Date().toISOString()}_\n\n${sections.slice(0, 2).join("\n")}${knownLines.length > 0 ? `\n### Known Issues (${knownLines.length})\n- See docs/known-issues/` : ""}\n`
    await writeFile(`${aiDir}/project-summary.md`, summaryContent, "utf-8")

    return JSON.stringify({
      regenerated: ["docs/ai-context/current-system-state.md", "docs/ai-context/project-summary.md"],
      sections_compressed: sections.length,
    })
  },
})
TOOLEOF

  cat > "$tdir/rule-violation-checker.ts" << 'TOOLEOF'
import { readdir, readFile } from "node:fs/promises"
import { tool } from "@opencode-ai/plugin"

export default tool({
  description: "Detect rule violations: bypassed services, missing audits, direct DB writes, undocumented routes, stale contracts",
  args: {
    sourceDirs: tool.schema.string().default("src,app").describe("Comma-separated source directories to scan"),
  },
  async execute(args, context) {
    const base = (context.worktree && context.worktree !== '/') ? context.worktree : context.directory
    const violations: { rule: string; file: string; severity: string }[] = []
    let passed = 0

    const srcDirs = args.sourceDirs.split(",").map(s => s.trim())
    const forbiddenPatterns = [
      { pattern: /db\.\w+\.\s*(create|update|delete|upsert)/g, rule: "Direct DB write (use service layer)", severity: "high" },
      { pattern: /prisma\.\w+\.\s*(create|update|delete|upsert)/g, rule: "Direct Prisma write (use service layer)", severity: "high" },
      { pattern: /await\s+\w+\s*\.\s*save\s*\(/g, rule: "Direct entity save (use repository)", severity: "medium" },
    ]

    for (const dir of srcDirs) {
      await scanDir(`${base}/${dir}`, violations, forbiddenPatterns)
    }

    let contractFiles: string[] = []
    try { contractFiles = (await readdir(`${base}/docs/contracts`)).filter(f => f.endsWith(".md")) } catch {}
    for (const cf of contractFiles) {
      try {
        const content = await readFile(`${base}/docs/contracts/${cf}`, "utf-8")
        if (content.match(/## Forbidden/)) passed++
      } catch {}
    }

    let apiDoc = ""
    try { apiDoc = await readFile(`${base}/docs/api/api-registry.md`, "utf-8") } catch {}
    for (const dir of srcDirs) {
      await scanDirForRoutes(`${base}/${dir}`, apiDoc, violations)
    }

    return JSON.stringify({ violations, passed_checks: passed + (apiDoc ? 1 : 0) })
  },
})

async function scanDir(dir: string, violations: any[], patterns: any[]) {
  try {
    const entries = await readdir(dir, { withFileTypes: true })
    for (const entry of entries) {
      const full = `${dir}/${entry.name}`
      if (entry.isDirectory() && !entry.name.startsWith(".") && entry.name !== "node_modules") {
        await scanDir(full, violations, patterns)
      } else if (entry.isFile() && (entry.name.endsWith(".ts") || entry.name.endsWith(".js"))) {
        const content = await readFile(full, "utf-8")
        for (const p of patterns) {
          if (content.match(p.pattern)) {
            violations.push({ rule: p.rule, file: full, severity: p.severity })
          }
        }
      }
    }
  } catch {}
}

async function scanDirForRoutes(dir: string, apiDoc: string, violations: any[]) {
  try {
    const entries = await readdir(dir, { withFileTypes: true })
    for (const entry of entries) {
      const full = `${dir}/${entry.name}`
      if (entry.isDirectory() && !entry.name.startsWith(".") && entry.name !== "node_modules") {
        await scanDirForRoutes(full, apiDoc, violations)
      } else if (entry.isFile() && (entry.name.endsWith(".ts") || entry.name.endsWith(".js"))) {
        const content = await readFile(full, "utf-8")
        const routeDefs = content.match(/(?:app|router)\.(?:get|post|put|patch|delete|options)\(['"`][^'"`]+/g)
        if (routeDefs) {
          for (const r of routeDefs) {
            if (!apiDoc.includes(r)) {
              violations.push({ rule: `Route ${r} not documented in api-registry.md`, file: full, severity: "medium" })
            }
          }
        }
      }
    }
  } catch {}
}
TOOLEOF

  msg "Tools installed → $tdir"
}

