show_status_opencode() {
  echo ""
  info "=== doc-it status (opencode) ==="
  echo ""

  local all_ok=true

  for f in doc-drift-checker.ts changelog-generator.ts traceability-generator.ts ai-context-generator.ts rule-violation-checker.ts; do
    if [ -f "$OPCODE_CONFIG_DIR/tools/$f" ]; then
      msg "  ✅ tools/$f"
    else
      err "  ❌ tools/$f"
      all_ok=false
    fi
  done

  echo ""
  if $all_ok; then
    msg "doc-it (opencode) tools are installed"
  else
    err "doc-it (opencode) is incomplete — run 'install' to fix"
  fi
  echo ""
}

show_status_kilo() {
  echo ""
  info "=== doc-it status (Kilo) ==="
  echo ""

  if [ -f "$KILO_PLUGIN_DIR/dist/doc-it.js" ]; then
    msg "  ✅ DocItPlugin: $KILO_PLUGIN_DIR/dist/doc-it.js"
  else
    err "  ❌ DocItPlugin missing"
  fi

  if [ -f "$KILO_PLUGIN_DIR/dist/index.js" ]; then
    msg "  ✅ Plugin index: $KILO_PLUGIN_DIR/dist/index.js"
  else
    err "  ❌ Plugin index missing"
  fi

  if grep -q "@opencode-tools/kilo-plugin" "$KILO_CONFIG_DIR/kilo.jsonc" 2>/dev/null; then
    msg "  ✅ Plugin registered in kilo.jsonc"
